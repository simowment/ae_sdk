{
  "name": "@simowment/aliexpress-sdk",
  "version": "0.6.1",
  "description": "A simple SDK for Aliexpress (dropshipping and affiliate) APIs.",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vitest",
    "test": "vitest run",
    "test:live": "vitest run src/live.test.ts",
    "auth": "node scripts/auth.mjs",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "lint": "tsc",
    "ci": "pnpm run lint && pnpm run test && pnpm run build",
    "release": "pnpm run lint && pnpm run test && pnpm run build && changeset publish",
    "prepare": "npm run build"
  },
  "keywords": [
    "typescript",
    "ae",
    "aliexpress",
    "sdk"
  ],
  "author": "simowment",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/simowment/ae_sdk"
  },
  "homepage": "https://github.com/simowment/ae_sdk",
  "bugs": {
    "url": "https://github.com/simowment/ae_sdk/issues"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.17.10",
    "tsup": "^7.2.0",
    "typescript": "^5.7.2",
    "vitest": "^0.34.6"
  }
}
